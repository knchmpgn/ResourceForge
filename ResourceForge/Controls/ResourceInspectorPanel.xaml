<UserControl x:Class="ResourceForge.Controls.ResourceInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ResourceForge.Converters"
             MinWidth="280"
             MaxWidth="430">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:CategoryToBrushConverter x:Key="CatBrush"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>

        <Style x:Key="MonoBox" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,3,0,6"/>
        </Style>

        <Style x:Key="InspectorButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel DataContext="{Binding DataContext.SelectedResource, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Visibility="{Binding Converter={StaticResource NullToVis}, ConverterParameter=Inverse}" VerticalAlignment="Center">
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Inspector" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Select a resource to inspect its metadata, preview, and edit actions." Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding Converter={StaticResource NullToVis}}">
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border CornerRadius="999" Padding="8,4" Background="{Binding Resource.Category, Converter={StaticResource CatBrush}}">
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding DisplayName}" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding SummaryLine}" Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>

                            <Border CornerRadius="10" Background="{DynamicResource CheckerBrush}" Height="140" Margin="0,14,0,0" Visibility="{Binding IsVisual, Converter={StaticResource BoolToVis}}">
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="PROPERTIES" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource MonoBox}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Language" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Language}" FontSize="12" Margin="8,3,0,3" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataSize}" FontSize="12" Margin="8,3,0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Category" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CategoryName}" FontSize="12" Margin="8,3,0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Dimensions" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3" Visibility="{Binding IsVisual, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Dimensions}" FontSize="12" Margin="8,3,0,3" Visibility="{Binding IsVisual, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Bit Depth" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3" Visibility="{Binding IsVisual, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding BitDepthDisplay}" FontSize="12" Margin="8,3,0,3" Visibility="{Binding IsVisual, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="CONTENT" Style="{StaticResource FieldLabel}" Visibility="{Binding StringContent, Converter={StaticResource NullToVis}}"/>
                    <Border Style="{StaticResource MonoBox}" Visibility="{Binding StringContent, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="{Binding StringContent}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" MaxHeight="180" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Border>

                    <TextBlock Text="VERSION INFO" Style="{StaticResource FieldLabel}" Visibility="{Binding VersionFields, Converter={StaticResource NullToVis}}"/>
                    <Border Style="{StaticResource MonoBox}" Visibility="{Binding VersionFields, Converter={StaticResource NullToVis}}">
                        <ItemsControl ItemsSource="{Binding VersionFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Margin="6,0,0,0" FontSize="11" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="MANIFEST XML" Style="{StaticResource FieldLabel}" Visibility="{Binding ManifestXml, Converter={StaticResource NullToVis}}"/>
                    <Border Style="{StaticResource MonoBox}" Visibility="{Binding ManifestXml, Converter={StaticResource NullToVis}}">
                        <TextBox Text="{Binding ManifestXml, Mode=OneWay}" FontFamily="Consolas" FontSize="10" IsReadOnly="True" TextWrapping="Wrap" MaxHeight="220" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <TextBlock Text="HEX PREVIEW" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource MonoBox}">
                        <TextBlock Text="{Binding HexPreview}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" MaxHeight="150" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Border>

                    <TextBlock Text="ACTIONS" Style="{StaticResource FieldLabel}"/>
                    <Button Content="Replace Resource" Style="{StaticResource InspectorButton}" Command="{Binding DataContext.ReplaceResourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="Export Resource" Style="{StaticResource InspectorButton}" Command="{Binding DataContext.ExportResourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="Copy Hex To Clipboard" Style="{StaticResource InspectorButton}" Command="{Binding DataContext.CopyResourceDataCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="Delete Resource" Style="{StaticResource DangerButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,4,0,0" Padding="10,8" FontSize="12" Command="{Binding DataContext.DeleteResourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
