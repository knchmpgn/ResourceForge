<Window x:Class="ResourceForge.Dialogs.BackupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backup Manager"
        Width="620" Height="460"
        MinWidth="480" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Backup Manager"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock x:Name="SubtitleText"
                       FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Backup list -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="BackupListControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{DynamicResource CardBackgroundBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13" FontFamily="Consolas"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding SizeDisplay}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text=" · "
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding AgeDisplay}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Restore"
                                            Style="{StaticResource ModernButton}"
                                            Padding="10,6" Margin="0,0,8,0"
                                            FontSize="12"
                                            Tag="{Binding}"
                                            Click="RestoreButton_Click"
                                            ToolTip="Restore this backup over the current file"/>

                                    <Button Grid.Column="2"
                                            Content="🗑"
                                            Style="{StaticResource DangerButton}"
                                            Width="34" Padding="0"
                                            FontSize="14"
                                            Tag="{Binding}"
                                            Click="DeleteButton_Click"
                                            ToolTip="Delete this backup"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText"
                   Grid.Row="1"
                   Text="No backups found for this file."
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Visibility="Collapsed"/>

        <!-- Purge all -->
        <Button Grid.Row="2"
                x:Name="PurgeAllButton"
                Content="Delete All Backups"
                Style="{StaticResource DangerButton}"
                HorizontalAlignment="Left"
                Padding="12,8" Margin="0,12,0,0"
                FontSize="12"
                Click="PurgeAll_Click"/>

        <!-- Close -->
        <Button Grid.Row="3"
                Content="Close"
                Style="{StaticResource AccentButton}"
                HorizontalAlignment="Right"
                Padding="20,9" Margin="0,12,0,0"
                FontSize="13"
                Click="Close_Click"/>
    </Grid>
</Window>
