<Window x:Class="ResourceForge.Dialogs.BatchReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Replace Icons"
        Width="540" Height="480"
        MinWidth="420" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Batch Replace Icons"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="Replace all icon group resources that contain a specific size."
                       FontSize="12" Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Step 1: Icon size selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,18">
            <TextBlock Text="1  FILTER BY SIZE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="SizeCombo"
                          Width="160"
                          SelectionChanged="SizeCombo_SelectionChanged"/>
                <TextBlock Text="px icon entries will be replaced"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>

            <TextBlock x:Name="AffectedGroupsText"
                       FontSize="12" Margin="0,8,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Step 2: Replacement file -->
        <StackPanel Grid.Row="2" Margin="0,0,0,18">
            <TextBlock Text="2  REPLACEMENT FILE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="10,8"
                        Background="{DynamicResource InputBackgroundBrush}">
                    <TextBlock x:Name="SelectedFileText"
                               Text="No file selected"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button Grid.Column="1"
                        Content="Browse…"
                        Style="{StaticResource ModernButton}"
                        Padding="14,8" Margin="8,0,0,0"
                        Click="Browse_Click"/>
            </Grid>

            <TextBlock Text="Supported: .ico, .png, .jpg, .bmp  (multi-size ICO recommended)"
                       FontSize="11" Margin="0,6,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Preview: affected icon groups -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="3  AFFECTED ICON GROUPS (PREVIEW)"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8"/>
            <Border BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    ClipToBounds="True" Height="120">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AffectedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Padding="10,4"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- Warning -->
        <Border Grid.Row="4"
                Margin="0,16,0,0"
                CornerRadius="6" Padding="12,8"
                Background="#20FF8C00">
            <TextBlock Text="⚠  A timestamped backup will be created automatically before making any changes."
                       FontSize="12" TextWrapping="Wrap"
                       Foreground="#CC6000"/>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="5" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Style="{StaticResource ModernButton}"
                    Padding="18,9" Margin="0,0,8,0"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2"
                    x:Name="ApplyButton"
                    Content="Apply Batch Replace"
                    Style="{StaticResource AccentButton}"
                    Padding="18,9"
                    IsEnabled="False"
                    Click="Apply_Click"/>
        </Grid>
    </Grid>
</Window>
