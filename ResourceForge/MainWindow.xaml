<Window x:Class="ResourceForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ResourceForge.Converters"
        xmlns:ctrl="clr-namespace:ResourceForge.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:ResourceForge.ViewModels"
        Title="ResourceForge 2026"
        Width="1380"
        Height="860"
        MinWidth="980"
        MinHeight="660"
        AllowDrop="True"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6" CornerRadius="0" UseAeroCaptionButtons="True" GlassFrameThickness="-1"/>
    </shell:WindowChrome.WindowChrome>

        <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.CommandBindings>
        <!-- placeholder to ensure ViewModel commands resolve under new namespace -->
    </Window.CommandBindings>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:CategoryToBrushConverter x:Key="CatBrush"/>
        <conv:CategoryToGlyphConverter x:Key="CatGlyph"/>
        <conv:CategoryFilterToGlyphConverter x:Key="CatFilterGlyph"/>
        <conv:CategoryFilterToLabelConverter x:Key="CatFilterLabel"/>
    </Window.Resources>

    <Grid>
        <Grid.Resources>
            <DataTemplate x:Key="ResourceGridTemplate" DataType="{x:Type vm:ResourceItemViewModel}">
                <Border MouseLeftButtonDown="ResourceCard_MouseLeftButtonDown" ToolTip="{Binding TooltipText}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ResourceCard}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardSelectedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
            <Grid Margin="0,0,0,12">
                            <Border Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}" CornerRadius="10" Background="{DynamicResource HeroBackgroundBrush}">
                                <Border Margin="10" CornerRadius="8" Background="{DynamicResource CheckerBrush}">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}" MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasThumbnail, Converter={StaticResource InvBoolToVis}}">
                                            <TextBlock Text="{Binding Resource.Category, Converter={StaticResource CatGlyph}}" FontFamily="Segoe Fluent Icons" FontSize="34" HorizontalAlignment="Center" Foreground="{Binding Resource.Category, Converter={StaticResource CatBrush}}"/>
                                            <TextBlock Text="{Binding CategoryName}" Margin="0,6,0,0" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0" Padding="8,4" CornerRadius="999" Background="{Binding Resource.Category, Converter={StaticResource CatBrush}}">
                                <TextBlock Text="{Binding TypeLabel}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding SummaryLine}" Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <DockPanel Margin="0,10,0,0">
                            <TextBlock Text="{Binding Dimensions}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding DataSize}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="74"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="&#xE943;" FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ResourceForge" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding WindowSubtitle}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Width="46" Height="48" Style="{StaticResource ToolbarButton}" Click="MinimizeButton_Click" ToolTip="Minimize">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
                </Button>
                <Button Width="46" Height="48" Style="{StaticResource ToolbarButton}" Click="MaximizeButton_Click" ToolTip="Maximize or restore">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
                </Button>
                <Button Width="46" Height="48" Click="CloseButton_Click" ToolTip="Close">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C42B1C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource TitleBarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource AccentButton}" Command="{Binding OpenFileCommand}" Padding="14,9" Margin="0,0,8,0" ToolTip="Open a PE binary (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Open File" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ReloadFileCommand}" Padding="10,9" Margin="0,0,4,0" ToolTip="Reload current file (F5)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Reload"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding CreateBackupCommand}" Padding="10,9" Margin="0,0,4,0" ToolTip="Create backup">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Backup"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ShowBackupsCommand}" Padding="10,9" Margin="0,0,4,0" ToolTip="View backups">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="History"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="10,6"/>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ReplaceResourceCommand}" Padding="10,9" Margin="0,0,4,0" ToolTip="Replace selected resource">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8AC;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Replace"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding BatchReplaceCommand}" Padding="10,9" Margin="0,0,4,0" ToolTip="Batch replace icon groups">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Batch"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ExportResourceCommand}" Padding="10,9" Margin="0,0,4,0" ToolTip="Export selected resource">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Export"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteResourceCommand}" Padding="10,9" ToolTip="Delete selected resource">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Delete"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FilterSummary}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding SelectedResourceSummary}" Margin="0,4,0,0" FontSize="11" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="4" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1" Margin="8,0,8,0" BorderThickness="0" Background="Transparent" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Search by name, type, or language (Ctrl+F)"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding ClearFiltersCommand}" Padding="8,5" Margin="0,0,4,0" ToolTip="Clear filters">
                                <TextBlock Text="&#xE894;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                            </Button>
                    <Border CornerRadius="8" Background="{DynamicResource SubtleAccentBrush}" Padding="8,5" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ToolbarButton}" Command="{Binding SetGridViewCommand}" Padding="6,2" Margin="0,0,8,0" ToolTip="Grid view">
                                <TextBlock Text="&#xECA5;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                            </Button>
                            <Button x:Name="ViewToggleButton" Style="{StaticResource ToolbarButton}" Padding="6,2" ToolTip="Toggle list/icon view" Click="ViewToggleButton_Click">
                                <TextBlock x:Name="ViewToggleIcon" Text="&#xE8EF;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                            </Button>
                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Size" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,6,0"/>
                                <Slider Width="120" Minimum="48" Maximum="300" Value="{Binding ThumbnailSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="2" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" MaxWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="260" MaxWidth="430"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Categories" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="Jump between resource families and narrow the workspace quickly." Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                    <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Background="Transparent" BorderThickness="0" Padding="0" ItemContainerStyle="{StaticResource SidebarListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="{Binding Converter={StaticResource CatFilterGlyph}}" DockPanel.Dock="Left" Margin="0,0,10,0" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Converter={StaticResource CatFilterLabel}}" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="Transparent" Cursor="SizeWE"/>

            <Grid Grid.Column="2" Margin="12">
                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16"/>
                <Grid Margin="12">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasFile, Converter={StaticResource InvBoolToVis}}">
                        <Border Width="88" Height="88" Background="{DynamicResource HeroBackgroundBrush}" CornerRadius="20">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe Fluent Icons" FontSize="42" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Open or drop a PE binary" Margin="0,18,0,4" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Inspect icons, manifests, version info, strings, and more from a single workspace." FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" MaxWidth="460"/>
                        <Button Style="{StaticResource AccentButton}" Command="{Binding OpenFileCommand}" Padding="24,12" Margin="0,22,0,0" Content="Open File"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasNoFilteredResults, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="40" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="No resources match the current filters" Margin="0,14,0,4" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Try a broader category or clear the current search." FontSize="13" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Button Style="{StaticResource ModernButton}" Command="{Binding ClearFiltersCommand}" Padding="18,10" Margin="0,18,0,0" Content="Clear Filters"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BusyMessage}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Large binaries can take a moment while resources and previews are scanned." Margin="0,8,0,0" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4" Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding FilteredResources}" ItemTemplate="{StaticResource ResourceGridTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <DataGrid ItemsSource="{Binding FilteredResources}" SelectedItem="{Binding SelectedResource, Mode=TwoWay}" Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}" SelectionChanged="ListView_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="48" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Width="28" Height="28">
                                            <Border Background="{DynamicResource HeroBackgroundBrush}" CornerRadius="8"/>
                                            <Image Source="{Binding Thumbnail}" Width="22" Height="22" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Resource.Category, Converter={StaticResource CatGlyph}}" FontFamily="Segoe Fluent Icons" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasThumbnail, Converter={StaticResource InvBoolToVis}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="170"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="120"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="90"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding DataSize}" Width="86"/>
                            <DataGridTextColumn Header="Dimensions" Binding="{Binding Dimensions}" Width="90"/>
                            <DataGridTextColumn Header="Depth" Binding="{Binding BitDepthDisplay}" Width="70"/>
                            <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" Background="Transparent" Cursor="SizeWE"/>

            <ctrl:ResourceInspectorPanel Grid.Column="4" DataContext="{Binding}"/>
        </Grid>

        <Border Grid.Row="4" Background="{DynamicResource StatusBarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="{Binding CurrentFilePath, FallbackValue=''}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.75" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
