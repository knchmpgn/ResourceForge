<Window x:Class="ResourceForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ResourceForge.Converters"
        xmlns:ctrl="clr-namespace:ResourceForge.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:ResourceForge.ViewModels"
        Title="ResourceForge 2026"
        Icon="pack://application:,,,/app.ico"
        Width="1380"
        Height="860"
        MinWidth="980"
        MinHeight="660"
        AllowDrop="True"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6" CornerRadius="0" UseAeroCaptionButtons="True" GlassFrameThickness="-1"/>
    </shell:WindowChrome.WindowChrome>

        <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.CommandBindings>
        <!-- placeholder to ensure ViewModel commands resolve under new namespace -->
    </Window.CommandBindings>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:CategoryToBrushConverter x:Key="CatBrush"/>
        <conv:CategoryToGlyphConverter x:Key="CatGlyph"/>
        <conv:CategoryFilterToGlyphConverter x:Key="CatFilterGlyph"/>
        <conv:CategoryFilterToLabelConverter x:Key="CatFilterLabel"/>
    </Window.Resources>

    <Grid>
        <Grid.Resources>
            <DataTemplate x:Key="ResourceGridTemplate" DataType="{x:Type vm:ResourceItemViewModel}">
                <Border MouseLeftButtonDown="ResourceCard_MouseLeftButtonDown" ToolTip="{Binding TooltipText}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ResourceCard}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardSelectedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}" CornerRadius="10,10,0,0" Background="{DynamicResource CheckerBrush}">
                            <Grid>
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" SnapsToDevicePixels="True" Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}" MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasThumbnail, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="{Binding Resource.Category, Converter={StaticResource CatGlyph}}" FontFamily="Segoe Fluent Icons" FontSize="34" HorizontalAlignment="Center" Foreground="{Binding Resource.Category, Converter={StaticResource CatBrush}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="0,0,0,0" Padding="10,8" Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <Border Grid.Column="1" Padding="6,3" CornerRadius="4" Background="{Binding Resource.Category, Converter={StaticResource CatBrush}}" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="62"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="&#xE943;" FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ResourceForge" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding WindowSubtitle}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Width="46" Height="48" Click="MinimizeButton_Click" ToolTip="Minimize">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
                </Button>
                <Button Width="46" Height="48" Click="MaximizeButton_Click" ToolTip="Maximize or restore">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE922;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
                </Button>
                <Button Width="46" Height="48" Click="CloseButton_Click" ToolTip="Close">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#C42B1C"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#A02410"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource TitleBarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource AccentButton}" Command="{Binding OpenFileCommand}" Padding="14,8" Margin="0,0,8,0" ToolTip="Open a PE binary (Ctrl+O)">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Open File" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ReloadFileCommand}" Padding="10,8" Margin="0,0,4,0" ToolTip="Reload current file (F5)">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reload" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding CreateBackupCommand}" Padding="10,8" Margin="0,0,4,0" ToolTip="Create backup">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Backup" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ShowBackupsCommand}" Padding="10,8" Margin="0,0,4,0" ToolTip="View backups">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="History" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="10,6"/>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ReplaceResourceCommand}" Padding="10,8" Margin="0,0,4,0" ToolTip="Replace selected resource">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8AC;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Replace" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding BatchReplaceCommand}" Padding="10,8" Margin="0,0,4,0" ToolTip="Batch replace icon groups">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Batch" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ExportResourceCommand}" Padding="10,8" Margin="0,0,4,0" ToolTip="Export selected resource">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Export" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding DeleteResourceCommand}" Padding="10,8" ToolTip="Delete selected resource">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="4" Background="{DynamicResource CardBackgroundBrush}" MinWidth="350">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                        </Style>
                    </Border.Style>
                    <Grid x:Name="SearchContainer">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1" Margin="8,0,8,0" Style="{StaticResource SearchTextBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Search by name, type, or language (Ctrl+F)" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                        <Button Grid.Column="2" Style="{StaticResource ToolbarButton}" Command="{Binding ClearFiltersCommand}" Padding="6,4" ToolTip="Clear filters">
                            <TextBlock Text="&#xE894;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="2" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" MaxWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="260" MaxWidth="430"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="12">
                    <ListBox DockPanel.Dock="Top" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Background="Transparent" BorderThickness="0" Padding="0" ItemContainerStyle="{StaticResource SidebarListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="{Binding Converter={StaticResource CatFilterGlyph}}" DockPanel.Dock="Left" Margin="0,0,10,0" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Converter={StaticResource CatFilterLabel}}" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="Transparent" Cursor="SizeWE"/>

            <Grid Grid.Column="2" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16"/>
                <Grid Grid.Row="0" Margin="12">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasFile, Converter={StaticResource InvBoolToVis}}">
                        <Border Width="88" Height="88" Background="{DynamicResource HeroBackgroundBrush}" CornerRadius="20">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe Fluent Icons" FontSize="42" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Open or drop a PE binary" Margin="0,18,0,4" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Inspect icons, manifests, version info, strings, and more from a single workspace." FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" MaxWidth="460"/>
                        <Button Style="{StaticResource AccentButton}" Command="{Binding OpenFileCommand}" Padding="24,12" Margin="0,22,0,0" Content="Open File"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasNoFilteredResults, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="40" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="No resources match the current filters" Margin="0,14,0,4" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Try a broader category or clear the current search." FontSize="13" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Button Style="{StaticResource ModernButton}" Command="{Binding ClearFiltersCommand}" Padding="18,10" Margin="0,18,0,0" Content="Clear Filters"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BusyMessage}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Large binaries can take a moment while resources and previews are scanned." Margin="0,8,0,0" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="6" Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding FilteredResources}" ItemTemplate="{StaticResource ResourceGridTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <DataGrid ItemsSource="{Binding FilteredResources}" SelectedItem="{Binding SelectedResource, Mode=TwoWay}" Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}" SelectionChanged="ListView_SelectionChanged" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="48" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Width="28" Height="28">
                                            <Border Background="{DynamicResource HeroBackgroundBrush}" CornerRadius="8"/>
                                            <Image Source="{Binding Thumbnail}" Width="22" Height="22" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Resource.Category, Converter={StaticResource CatGlyph}}" FontFamily="Segoe Fluent Icons" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasThumbnail, Converter={StaticResource InvBoolToVis}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="170"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="120"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="90"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding DataSize}" Width="86"/>
                            <DataGridTextColumn Header="Dimensions" Binding="{Binding Dimensions}" Width="90"/>
                            <DataGridTextColumn Header="Depth" Binding="{Binding BitDepthDisplay}" Width="70"/>
                            <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12" Margin="0,12,0,0" CornerRadius="12" Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="ViewToggleButton" Style="{StaticResource ToolbarButton}" Padding="10,8" Margin="0,0,12,0" ToolTip="Toggle list/icon view" Click="ViewToggleButton_Click">
                            <TextBlock x:Name="ViewToggleIcon" Text="&#xE8EF;" FontFamily="Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                        <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,12,0"/>
                        <TextBlock Text="Size" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,0"/>
                        <Slider x:Name="ThumbnailSlider" Width="160" Minimum="48" Maximum="256" Value="{Binding ThumbnailSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" PreviewMouseWheel="Slider_PreviewMouseWheel" IsSnapToTickEnabled="True" TickPlacement="BottomRight" TickFrequency="16">
                            <Slider.Style>
                                <Style TargetType="Slider">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Slider">
                                                <Border Background="Transparent" Padding="0,8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TickBar Grid.Row="0" Placement="Top" Height="4" Fill="{DynamicResource BorderBrush}" Ticks="{TemplateBinding Ticks}" Margin="12,0"/>
                                                        <Track Grid.Row="1" x:Name="PART_Track">
                                                            <Track.DecreaseRepeatButton>
                                                                <RepeatButton Style="{StaticResource HorizontalSliderButtonStyle}" Background="{DynamicResource AccentBrush}" Height="4"/>
                                                            </Track.DecreaseRepeatButton>
                                                            <Track.IncreaseRepeatButton>
                                                                <RepeatButton Style="{StaticResource HorizontalSliderButtonStyle}" Background="{DynamicResource BorderBrush}" Height="4"/>
                                                            </Track.IncreaseRepeatButton>
                                                            <Track.Thumb>
                                                                <Thumb Width="3" Height="20">
                                                                    <Thumb.Template>
                                                                        <ControlTemplate>
                                                                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="1.5"/>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                        <TickBar Grid.Row="2" Placement="Bottom" Height="4" Fill="{DynamicResource BorderBrush}" Ticks="{TemplateBinding Ticks}" Margin="12,0"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Slider.Style>
                            <Slider.Ticks>48,64,80,96,112,128,144,160,176,192,208,224,240,256</Slider.Ticks>
                        </Slider>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" Background="Transparent" Cursor="SizeWE"/>

            <ctrl:ResourceInspectorPanel Grid.Column="4" DataContext="{Binding}"/>
        </Grid>

        <Border Grid.Row="4" Background="{DynamicResource StatusBarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="{Binding CurrentFilePath, FallbackValue=''}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.75" Foreground="{DynamicResource SecondaryTextBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
